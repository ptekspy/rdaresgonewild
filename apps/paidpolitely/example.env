# PaidPolitely.com public landing site
# Copy this file to .env.local for local development, or add the same values in Vercel.

# Public site URL used for metadata, sitemap, robots, and canonical links.
NEXT_PUBLIC_SITE_URL="https://paidpolitely.com"

# Main acquisition email for both advertisers and subreddit/community partners.
NEXT_PUBLIC_CONTACT_EMAIL="ads@paidpolitely.com"

# Human-readable network/brand name.
NEXT_PUBLIC_NETWORK_NAME="PaidPolitely"

# Optional operational endpoints. These are shown nowhere by default, but kept here
# so this app can sit cleanly beside the rest of the PaidPolitely network.
NEXT_PUBLIC_ADS_API_URL="https://ads.paidpolitely.com"
NEXT_PUBLIC_API_URL="https://api.paidpolitely.com"
NEXT_PUBLIC_ANALYTICS_URL="https://analytics.paidpolitely.com"

# Set to true if you want the landing page to link directly to Vercel preview sites.
# For public launch, false is cleaner until the custom domains are bought.
NEXT_PUBLIC_SHOW_PREVIEW_SITE_LINKS="false"

# Email routing intent. Configure this with your email provider/DNS, not in Next.js.
# Needed inbox/alias: ads@paidpolitely.com
# Suggested catch-all: *@paidpolitely.com -> your chosen mailbox
PAIDPOLITELY_REQUIRED_INBOX="ads@paidpolitely.com"
PAIDPOLITELY_CATCH_ALL="*@paidpolitely.com"
