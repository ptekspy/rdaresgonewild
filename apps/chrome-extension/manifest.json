{
  "manifest_version": 3,
  "name": "Paid Politely Reddit Sync",
  "description": "Crawl the Reddit page you are viewing and sync post details to Paid Politely.",
  "version": "0.2.2",
  "action": {
    "default_title": "Paid Politely Reddit Sync",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": [
    "https://*.reddit.com/*",
    "https://api.paidpolitely.com/*",
    "http://localhost:8787/*"
  ]
}
