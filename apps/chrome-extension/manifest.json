{
  "manifest_version": 3,
  "name": "Paid Politely Local Reddit Crawler",
  "description": "Parse Reddit listing pages directly from the DOM and stream posts to the local Paid Politely DB writer.",
  "version": "0.3.0",
  "action": {
    "default_title": "Paid Politely Local Reddit Crawler",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": [
    "https://*.reddit.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
