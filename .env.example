# rdaresgonewild.com Environment Variables
# Copy to .env.local in each app

# Database (shared Postgres instance)
DATABASE_DRIVER="neon"
DATABASE_URL="postgresql://postgres:postgres@localhost:5444/paidpolitely"

# Reddit session cookie for the crawler (copy from browser DevTools)
REDDIT_COOKIE="your-reddit-cookie-here"

# Admin app protection secret
ADMIN_SECRET="change-me-to-a-random-string"
ADMIN_SESSION_SECRET="change-me-to-a-long-random-session-secret"

# Paid Politely Ads
ADS_PUBLIC_BASE_URL="https://ads.paidpolitely.com"
ADS_TOKEN_SECRET="change-me-to-a-long-random-token-secret"
ADS_HASH_SALT="change-me-to-a-long-random-hash-salt"
ADS_ALLOWED_ORIGINS="https://rdaresgonewild.com,https://www.rdaresgonewild.com,https://rflashingandflaunting.com,https://www.rflashingandflaunting.com,https://rrealpublicnudity.com,https://www.rrealpublicnudity.com,https://rexhibitionistgirl.com,https://www.rexhibitionistgirl.com,https://rchanginginpublic.com,https://www.rchanginginpublic.com,https://rcmnf.com,https://www.rcmnf.com,https://ronlyonenaked.com,https://www.ronlyonenaked.com,https://routdoorgirls.com,https://www.routdoorgirls.com,https://rpermanentnude.com,https://www.rpermanentnude.com,https://rbralessforever.com,https://www.rbralessforever.com,http://localhost:6789"

# Consumer ad settings
# Use rdaresgonewild, rflashingandflaunting, rrealpublicnudity,
# rexhibitionistgirl, rchanginginpublic, rcmnf, ronlyonenaked,
# routdoorgirls, rpermanentnude, or rbralessforever.
NEXT_PUBLIC_SITE_KEY="rdaresgonewild"
NEXT_PUBLIC_ADS_API_URL="https://ads.paidpolitely.com"

# Paid Politely API / extension ingest
API_PUBLIC_BASE_URL="https://api.paidpolitely.com"
# Set this to the published Chrome extension origin after publication.
EXTENSION_ORIGIN="*"

# Crawler target subreddit for a legacy one-board worker.
REDDIT_SUBREDDIT="daresgonewild"

# Multi-board crawler target list.
CRAWLER_SUBREDDITS="daresgonewild,FlashingAndFlaunting,RealPublicNudity,ExhibitionistGirl,ChanginginPublic,CMNF,onlyonenaked,outdoorgirls,Permanent_Nude,BralessForever"

# Crawler rate limit (requests per minute, default 25)
CRAWLER_RPM=25

# Optional crawler limits
# CRAWLER_MAX_PAGES=50
# CRAWLER_LOOP_INTERVAL_MS=300000
# CRAWLER_LOOP_ERROR_DELAY_MS=60000
