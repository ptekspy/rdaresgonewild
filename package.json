{
  "name": "rdaresgonewild",
  "private": true,
  "scripts": {
    "build": "pnpm db:generate && turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "postinstall": "pnpm db:generate",
    "db:generate": "pnpm --filter @rdgw/database db:generate",
    "db:push": "pnpm --filter @rdgw/database db:push"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0"
}
