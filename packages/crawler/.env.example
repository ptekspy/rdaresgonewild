# Database
DATABASE_DRIVER=neon
DATABASE_URL=

# Browser-backed Reddit crawler, no OAuth needed.
# Start Chrome/Edge with --remote-debugging-port=9222 and open a logged-in reddit.com tab.
REDDIT_BROWSER_DEBUG_URL=http://127.0.0.1:9222
REDDIT_BROWSER_TAB_MATCH=reddit.com
REDDIT_SUBREDDIT=daresgonewild

# Optional cookie-backed crawler fallback.
# Use only if you want pnpm crawler:scan / crawler:worker instead of the :browser scripts.
REDDIT_COOKIE=
REDDIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120 Safari/537.36

# Crawler behaviour
CRAWLER_RPM=25
CRAWLER_MAX_PAGES=25
CRAWLER_BACKFILL_MAX_PAGES=1000
CRAWLER_TOP_TIME_WINDOWS=day,week,month,year,all
CRAWLER_SUBREDDIT_BOOTSTRAP_ON_START=false
CRAWLER_HTML_DIAGNOSTICS=false
CRAWLER_LOOP_INTERVAL_MS=300000
CRAWLER_LOOP_ERROR_DELAY_MS=60000
CRAWLER_IDLE_SLEEP_MS=60000
CRAWLER_NEW_INTERVAL_MS=3600000
CRAWLER_DAILY_SORT_INTERVAL_MS=86400000
CRAWLER_USER_RECRAWL_MS=86400000

# Rendered HTML scrolling is kept for diagnostics/manual imports only.
CRAWLER_SCROLL_WAIT_MS=1500
CRAWLER_SCROLL_STABLE_ROUNDS=3
CRAWLER_MAX_SCROLLS_PER_PAGE=500
CRAWLER_BROWSER_USER_DATA_DIR=
CRAWLER_BROWSER_EXECUTABLE=
