{
  "name": "@rdgw/crawler",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "scan": "node dist/bin/scan.js",
    "scan:user": "node dist/bin/scan-user.js",
    "scan:html": "node dist/bin/scan-html.js",
    "worker": "node dist/bin/worker.js"
  },
  "dependencies": {
    "@rdgw/database": "workspace:*",
    "@rdgw/playbook": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}
